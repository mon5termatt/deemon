#!/usr/bin/env bash
set -euo pipefail

resolve_path() {
  local path="$1"
  local dir

  while [[ -L "${path}" ]]; do
    dir="$(cd -P "$(dirname "${path}")" && pwd)"
    path="$(readlink "${path}")"
    [[ "${path}" != /* ]] && path="${dir}/${path}"
  done

  cd -P "$(dirname "${path}")" && pwd
}

SCRIPT_DIR="$(resolve_path "${BASH_SOURCE[0]}")"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
VENV_PYTHON="${ROOT_DIR}/.venv/bin/python"

if [[ -x "${VENV_PYTHON}" ]]; then
  exec "${VENV_PYTHON}" -m deemon.__main__ "$@"
fi

echo "Error: deemon virtualenv not found at ${VENV_PYTHON}" >&2
echo "From repo root, run: python3 -m venv .venv && source .venv/bin/activate && pip install -r requirements.txt && pip install -e ." >&2
exit 127
